# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP (for error alert emails)
# Use a Gmail App Password, NOT your real Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
GMAIL_ADDRESS=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here
